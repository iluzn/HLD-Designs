rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public comment threads, one flat list per page.
    match /comments/{commentId} {
      // Anyone can read comments.
      allow read: if true;

      // Only signed-in users can post, and only as themselves. Basic
      // validation guards against oversized or malformed payloads.
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 2000
                    && request.resource.data.page is string
                    && request.resource.data.page.size() <= 300
                    && (!('parentId' in request.resource.data.keys())
                        || request.resource.data.parentId == null
                        || (request.resource.data.parentId is string
                            && request.resource.data.parentId.size() <= 64))
                    // Only the admin account may tag a comment as admin.
                    && (!('role' in request.resource.data.keys())
                        || request.resource.data.role == null
                        || (request.resource.data.role == 'admin'
                            && request.auth.token.email == 'systemcraft.in@gmail.com'));

      // Users can delete their own comments; the admin can delete any comment.
      allow delete: if request.auth != null
                    && (resource.data.uid == request.auth.uid
                        || request.auth.token.email == 'systemcraft.in@gmail.com');

      // Comments are immutable for regular users. The admin may update
      // (used to backfill the admin role tag on older comments).
      allow update: if request.auth != null
                    && request.auth.token.email == 'systemcraft.in@gmail.com';
    }

    // In-app notifications. A notification is addressed to a recipient and
    // created by another signed-in user (e.g. someone replying to you).
    match /notifications/{notifId} {
      // Only the recipient can read their notifications.
      allow read: if request.auth != null && resource.data.recipientUid == request.auth.uid;

      // Any signed-in user can create a notification for someone else.
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.recipientUid is string
                    && request.resource.data.recipientUid != request.auth.uid
                    && request.resource.data.type is string
                    && request.resource.data.read == false
                    && request.resource.data.page is string
                    && request.resource.data.page.size() <= 300;

      // Recipients can mark their notifications read or delete them.
      allow update, delete: if request.auth != null && resource.data.recipientUid == request.auth.uid;
    }
  }
}
