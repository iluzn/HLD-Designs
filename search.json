---
layout: none
permalink: /search.json
---
[
{% assign searchable = site.pages | where_exp: "p", "p.title and p.url != '/search.json' and p.url != '/404.html' and p.url != '/search/'" %}
{% for page in searchable %}
{
  "title": {{ page.title | jsonify }},
  "url": "{{ page.url }}",
  "description": {{ page.description | default: "" | jsonify }},
  "content": {{ page.content | strip_html | strip_newlines | truncatewords: 300 | jsonify }}
}{% unless forloop.last %},{% endunless %}
{% endfor %}
]
